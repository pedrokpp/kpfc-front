{
	"name": "kpfc-front",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
